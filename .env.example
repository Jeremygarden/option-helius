# Options Dashboard environment template
# Copy to .env and fill in real credentials locally. Never commit .env.

# ---- Frontend ----
# Override the backend URL for browser-side fetch calls (default: http://localhost:8000)
# In Docker Compose this is set to http://backend:8000 automatically.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Existing API keys ----
FLASHALPHA_API_KEY=
ALPHAVANTAGE_API_KEY=
FRED_API_KEY=

# ---- Database / cache ----
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgres://postgres:postgres@timescaledb:5432/postgres
POSTGRES_PASSWORD=postgres

# ---- Docker Compose profiles ----
# Leave empty for the default stack; set to ibkr or use `docker compose --profile ibkr ...` to start the sidecar.
COMPOSE_PROFILES=

# ---- IBKR backend provider ----
# Keep disabled until IB Gateway is logged in and market data permissions are confirmed.
IBKR_ENABLED=false
IBKR_HOST=localhost
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_TYPE=paper
IBKR_CONNECT_TIMEOUT=30
IBKR_READONLY=true

# ---- IB Gateway sidecar ----
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
TRADING_MODE=PAPER
IBC_VERSION=3.18.0
TWS_VERSION=1019
TZ=America/New_York
VNC_PASSWORD=changeme123

# ---- IB Gateway published ports ----
PAPER_PORT=4002
LIVE_PORT=4001
VNC_PORT=6080

# ---- IBKR data client safety limits ----
MAX_TICKERS=100
ATM_STRIKE_RADIUS=8
RECONNECT_DELAY=5
MAX_RECONNECT_ATTEMPTS=0
